DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=false
DJANGO_USE_SQLITE=false
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost
SESSION_COOKIE_SECURE=false
CSRF_COOKIE_SECURE=false
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=false
SECURE_HSTS_PRELOAD=false

POSTGRES_DB=dchat
POSTGRES_USER=dchat
POSTGRES_PASSWORD=dchat
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

REDIS_URL=redis://redis:6379/0

CAPTCHA_ENABLED=true
CAPTCHA_PROVIDER=math
EMAIL_VERIFICATION_REQUIRED=false
ENABLE_METRICS=false
ENABLE_REDIS_CACHE=false

DEFAULT_ACCENT_HEX=#f39c12
DEFAULT_BG_HEX=#0f1217
DEFAULT_SURFACE_HEX=#1a1f29
DEFAULT_TEXT_HEX=#e5e7eb
DEFAULT_MUTED_TEXT_HEX=#9ca3af
DEFAULT_LINK_HEX=#7cc4ff

MAX_UPLOAD_MB=8
EMBED_PARENT_DOMAIN=localhost
